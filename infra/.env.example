# Copy this file to `.env` in the same folder (`infra/.env`).
# Real secrets go in `.env` only — that file is gitignored and never committed.

# Redis (local Docker — matches the `redis` service in docker-compose.yml)
# Use `redis` as the hostname when ai-service runs inside Docker Compose.
# Use `localhost` when your Python app runs directly on your machine.
REDIS_URL=redis://redis:6379

# Appwrite — server-side only (API key never goes in the dashboard)
# API key scopes required: databases.read, documents.read, documents.write
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-project-id
APPWRITE_API_KEY=your-api-key-with-databases-write
APPWRITE_DATABASE_ID=your-database-id
APPWRITE_BUSINESSES_COLLECTION_ID=businesses

# Dashboard dev server origin (CORS)
CORS_ORIGINS=http://localhost:5173
