# Copy to .env.local in this folder (apps/dashboard/.env.local).
# Vite loads .env.local automatically and never commits it.

# Appwrite Cloud → your project → Settings
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your-project-id-here

# Appwrite → Databases → botuncle → copy IDs from URL / collection settings
VITE_APPWRITE_DATABASE_ID=your-database-id
VITE_APPWRITE_BUSINESSES_COLLECTION_ID=your-businesses-collection-id
VITE_APPWRITE_PLANS_COLLECTION_ID=your-plans-collection-id

# Local ai-service (Docker Compose)
VITE_AI_SERVICE_URL=http://localhost:8000
